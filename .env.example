# =============================================================================
# PawPath Pro — Environment Variables
# Copy this file to .env.local and fill in all values before running.
# NEVER commit .env.local to version control.
# =============================================================================

# ─── App ─────────────────────────────────────────────────────────────────────
# The root domain for tenant subdomains (e.g. sarahswalks.pawpathpro.com)
NEXT_PUBLIC_APP_DOMAIN=pawpathpro.com

# Platform admin email — only this user can access /admin
PLATFORM_ADMIN_EMAIL=geffrey@pawpathpro.com

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to the browser. Server-side only.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Run `npx tsx scripts/setup-stripe.ts` to generate these price IDs
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# Webhook signing secret — from Stripe Dashboard → Webhooks
# Endpoint: https://pawpathpro.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Optional: Email (Resend) ─────────────────────────────────────────────────
# Sign up at https://resend.com — generous free tier
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@pawpathpro.com
